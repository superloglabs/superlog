DATABASE_URL=postgres://postgres:postgres@localhost:5434/superlog
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=superlog
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
POLL_INTERVAL_MS=3000
BATCH_SIZE=500
INVESTIGATION_BATCH_SIZE=20
COMMUNITY_AGENT_RUNNER_STATE_DIR=tmp/community-agent-runs
ANTHROPIC_API_KEY=
# GitHub App credentials — the worker uses these to mint installation tokens for
# opening PRs. Must match the App configured in apps/api (see apps/api/.env.example).
# Provide the PEM inline via GITHUB_APP_PRIVATE_KEY (escape newlines as \n) or
# base64-encoded via GITHUB_APP_PRIVATE_KEY_BASE64.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_BASE64=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Railway connector: the puller job refreshes OAuth tokens (same app as the
# api) and forwards pulled telemetry to the proxy intake. RAILWAY_INTAKE_URL
# defaults to the local proxy (http://localhost:$PROXY_APP_PORT or :4000).
RAILWAY_CLIENT_ID=
RAILWAY_CLIENT_SECRET=
RAILWAY_INTAKE_URL=

# Render connector: the puller job reads each installation's stored API key
# (decrypted with AGENT_SECRETS_KEY, which must match the api's) and forwards
# pulled telemetry to the proxy intake. RENDER_INTAKE_URL defaults to the
# local proxy (http://localhost:$PROXY_APP_PORT or :4000).
RENDER_INTAKE_URL=

# Google Cloud Monitoring puller. Runtime auth uses Application Default
# Credentials (typically AWS workload identity federation), not a service
# account key. Reads are quota-attributed to the integration project and stop
# at the persisted per-connection monthly returned-series ceiling.
GCP_INTEGRATION_PROJECT_ID=
GCP_METRICS_INTAKE_URL=
GCP_METRICS_MONTHLY_SERIES_LIMIT=100000000
GCP_WORKLOAD_IDENTITY_CONFIG=
