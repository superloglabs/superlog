DATABASE_URL=postgres://postgres:postgres@localhost:5434/superlog
COLLECTOR_URL=http://localhost:4318
PORT=4000

# Optional durable ingest buffer. When INGEST_QUEUE_URL is unset, the proxy
# forwards directly to COLLECTOR_URL.
INGEST_QUEUE_URL=
INGEST_OVERSIZE_BUCKET=
INGEST_OVERSIZE_PREFIX=otlp-oversize
INGEST_QUEUE_CONSUMER_ENABLED=true
INGEST_QUEUE_CONSUMER_CONCURRENCY=4
INGEST_QUEUE_MAX_MESSAGE_BYTES=240000
# Region for the SQS/S3 ingest buffer (only needed when INGEST_QUEUE_URL is set).
AWS_REGION=

# Render log-stream sink: TCP port for the RFC 5424 syslog listener the
# connector registers as the workspace's log stream destination (fronted by a
# TLS-terminating NLB in prod). Unset = listener disabled.
RENDER_SYSLOG_PORT=
