DATABASE_URL=postgres://postgres:postgres@localhost:5434/superlog
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=superlog
BETTER_AUTH_SECRET=replace_me_32_byte_random_string
BETTER_AUTH_URL=http://localhost:4100
STATE_SIGNING_SECRET=replace_me_32_byte_random_string
# Encrypts integration secrets at rest (AWS connect external IDs, Slack/Linear
# tokens). Required for any integration that stores a secret — without it those
# routes 500. Must base64-decode to exactly 32 bytes: openssl rand -base64 32
AGENT_SECRETS_KEY=
# OAuth provider credentials for Better Auth (set per-environment).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth credentials — used both for Better Auth "Sign in with GitHub"
# and as the fallback OAuth client for the GitHub App connect flow.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub App credentials — required for the "Connect GitHub" / "Install GitHub
# App" flow in the dashboard (repo inspection + opening PRs). Without GITHUB_APP_SLUG
# the API returns 503 from /api/github/install-url and the connect button does
# nothing. Register a GitHub App at https://github.com/settings/apps to obtain
# these; the slug is the URL segment in https://github.com/apps/<slug>.
GITHUB_APP_SLUG=
GITHUB_APP_ID=
# PEM private key from the GitHub App. Either inline (escape newlines as \n) via
# GITHUB_APP_PRIVATE_KEY, or base64-encode the PEM into GITHUB_APP_PRIVATE_KEY_BASE64.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_BASE64=
# Shared secret configured on the GitHub App webhook; required to verify
# /github/webhook deliveries.
GITHUB_APP_WEBHOOK_SECRET=
# Optional — both default to http://localhost:4100/github/<install|author>/callback.
# Register BOTH as Callback URLs on the App (install = "Connect GitHub", author =
# "Refresh access"), or the App rejects the redirect_uri.
GITHUB_INSTALL_OAUTH_REDIRECT_URL=
GITHUB_AUTHOR_OAUTH_REDIRECT_URL=
# Resend (transactional email). Without these the API logs the verification
# / password-reset link to stderr instead of sending real email — fine for
# worktree dev, must be set in prod.
RESEND_API_KEY=
SUPERLOG_FROM_EMAIL=Superlog <no-reply@superlog.sh>
SUPERLOG_REPLY_TO_EMAIL=
WEB_ORIGIN=http://localhost:5173
PORT=4100
LOOPS_API_KEY=
LOOPS_WELCOME_EVENT_NAME=superlogWelcome
# Server-side product analytics (PostHog). Optional: unset means the server-side
# lifecycle events (user_signed_up, organization_created) are simply not emitted
# — fine for local dev, worktrees, and self-host. Use the same project token as
# the web app's VITE_PUBLIC_POSTHOG_PROJECT_TOKEN. Host defaults to EU cloud.
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://eu.i.posthog.com
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_OAUTH_REDIRECT_URL=http://localhost:4100/slack/oauth/callback
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=
LINEAR_OAUTH_REDIRECT_URL=http://localhost:4100/linear/oauth/callback
# Notion connector (public OAuth integration). Create one at
# https://www.notion.so/my-integrations (type: public). The redirect URL must
# match the integration's configured redirect URI exactly.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URL=http://localhost:4100/notion/oauth/callback
# Sentry Cloud public integration. See docs/sentry-app-setup.md. Self-hosted
# Sentry is not supported by this connector.
SENTRY_APP_SLUG=
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=
SENTRY_OAUTH_REDIRECT_URL=http://localhost:4100/sentry/oauth/callback
# AWS connect (CloudFormation-based "connect your data" onboarding). When unset,
# the "Connect AWS" flow returns 500 "AWS connect is not configured". The first
# two are the minimum to enable connect; the combined-stack + Firehose intake
# trio below enables the one-step (scrape role + metric + log streaming) launch.
# SUPERLOG_AWS_ACCOUNT_ID is passed as a stack *parameter* (never baked into the
# public template), so prod topology stays out of the open-core repo.
SUPERLOG_AWS_ACCOUNT_ID=
AWS_CONNECT_TEMPLATE_URL=
# Optional: callback URL for zero-paste connect. The stack's in-stack Lambda POSTs
# the created role ARN here (e.g. https://<api-host>/api/cloud-connections/callback).
AWS_CONNECT_CALLBACK_URL=
# One-step combined connect (all three required together):
AWS_CONNECT_STACK_TEMPLATE_URL=
AWS_FIREHOSE_METRICS_INTAKE_URL=
AWS_FIREHOSE_LOGS_INTAKE_URL=
# Legacy per-signal stream templates (only if not using the combined stack):
AWS_METRICS_TEMPLATE_URL=
AWS_LOGS_TEMPLATE_URL=

# Railway connector ("Login with Railway" OAuth app). Both required to enable
# the connector; the callback URL must exactly match a redirect URI registered
# on the OAuth app (defaults to http://localhost:4100/railway/oauth/callback).
RAILWAY_CLIENT_ID=
RAILWAY_CLIENT_SECRET=
RAILWAY_OAUTH_REDIRECT_URL=

# Google Cloud connector. OAuth is used only during setup; the access token is
# discarded after creating the customer Logging sink and read-only IAM grants.
# Pub/Sub resources live in GCP_INTEGRATION_PROJECT_ID and push to the proxy.
# API/worker runtime credentials should use Application Default Credentials
# (for example AWS workload identity federation), never a downloaded key.
GCP_OAUTH_CLIENT_ID=
GCP_OAUTH_CLIENT_SECRET=
GCP_OAUTH_REDIRECT_URI=http://localhost:4100/gcp/oauth/callback
GCP_INTEGRATION_PROJECT_ID=
GCP_READER_SERVICE_ACCOUNT_EMAIL=
GCP_PUBSUB_PUSH_SERVICE_ACCOUNT_EMAIL=
GCP_PUBSUB_PUSH_ENDPOINT=http://localhost:4000/gcp/pubsub
GCP_PUBSUB_PUSH_AUDIENCE=http://localhost:4000/gcp/pubsub
# Non-secret external-account JSON generated for the runtime's AWS workload
# identity. Optional on GCP-hosted runtimes where ADC is already available.
GCP_WORKLOAD_IDENTITY_CONFIG=

# The Render connector needs no client credentials here — users paste their own
# Render API key. It only requires AGENT_SECRETS_KEY (above) so the key can be
# stored encrypted. RENDER_STREAM_INTAKE_URL is the public intake origin the
# connector registers as the workspace's METRICS stream (OTLP push)
# destination. RENDER_SYSLOG_INTAKE is the public TLS syslog host:port it
# registers as the LOG stream destination (Render log streams push RFC 5424
# syslog, not HTTP). Either unset → that signal falls back to API polling.
RENDER_STREAM_INTAKE_URL=
RENDER_SYSLOG_INTAKE=
